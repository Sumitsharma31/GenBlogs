{
  "name": "ai-blog-platform",
  "version": "1.0.0",
  "description": "Unified runner for AI Blog Platform",
  "scripts": {
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build": "npm run install:all && npm run build --prefix backend",
    "prestart": "npm run install:all",
    "start": "npm run start --prefix backend",
    "install:all": "npm install --prefix backend"
  },
  "dependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
